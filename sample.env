# Hutrol Configuration Fallback
# You can set variables here, but the recommended way is using the CLI:
# `hutrol config set OPENROUTER_API_KEY <your-key>`

PROVIDER=openrouter

# OpenRouter Settings (Cloud Mode)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct

# Ollama Settings (Local Air-Gapped Mode)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3
